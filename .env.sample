OPENAI_BASE_URL=your-openai-base-url-here
OPENAI_API_KEY=your-api-key-here
DEFAULT_MODEL=your-default-model-here

# Web search tool configuration
# Provider to use for the built-in web_search tool: "duckduckgo" (default) or "tavily"
WEB_SEARCH_PROVIDER=duckduckgo
# Required when WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# Proxy API key — enforced for non-localhost requests (e.g. via ngrok)
# Leave empty to disable key enforcement (all origins allowed without auth)
PROXY_API_KEY=

# Debug logging
# Set to true to write full request/response logs to daily rotating files in DEBUG_LOG_DIR
DEBUG_MODE=false
# Directory where daily debug log files are written (created automatically if missing)
DEBUG_LOG_DIR=logs
