OPENAI_BASE_URL=your-openai-base-url-here
OPENAI_API_KEY=your-api-key-here
DEFAULT_MODEL=your-default-model-here

# Web search tool configuration
# Provider to use for the built-in web_search tool: "duckduckgo" (default) or "tavily"
WEB_SEARCH_PROVIDER=duckduckgo
# Required when WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
